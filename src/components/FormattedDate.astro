---
interface Props {
	date: Date;
	/** 紧凑格式：2024.06 */
	compact?: boolean;
}

const { date, compact = false } = Astro.props;
const formatter = compact
	? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit' })
	: new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<time datetime={date.toISOString()}>{formatter.format(date)}</time>
