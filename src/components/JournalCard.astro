---
import type { CollectionEntry } from 'astro:content';
import Cover from './Cover.astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
	entry: CollectionEntry<'journal'>;
}

const { data, id } = Astro.props.entry;
---

<a class="card" href={`/journal/${id}/`} data-reveal>
	<div class="card-media">
		<Cover seed={data.title} image={data.cover} imageAlt={data.coverAlt} label={data.location} />
	</div>
	<div class="card-body">
		<div class="card-meta">
			<span class="card-loc">{data.location}</span>
			<span class="card-dot" aria-hidden="true">·</span>
			<FormattedDate date={data.date} />
		</div>
		<h3 class="card-title">{data.title}</h3>
		<p class="card-summary">{data.summary}</p>
		{
			data.tags.length > 0 && (
				<div class="card-tags">
					{data.tags.slice(0, 3).map((t) => (
						<span class="tag">{t}</span>
					))}
				</div>
			)
		}
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		color: inherit;
		height: 100%;
	}
	.card-media {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-lg);
		aspect-ratio: 4 / 3;
		background: var(--bg-subtle);
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.4s ease;
	}
	.card-media :global(.cover) {
		height: 118%;
		will-change: transform;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.card:hover .card-media {
		box-shadow: var(--shadow);
	}
	.card:hover .card-media :global(.cover) {
		transform: scale(1.04);
	}
	.card-body {
		padding: 1.1rem 0.2rem 0;
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		color: var(--text-faint);
	}
	.card-loc {
		color: var(--accent);
		font-weight: 600;
	}
	.card-title {
		margin: 0.5rem 0 0;
		font-size: 1.4rem;
		line-height: 1.2;
		transition: color 0.2s ease;
	}
	.card:hover .card-title {
		color: var(--accent);
	}
	.card-summary {
		margin: 0.5rem 0 0;
		color: var(--text-muted);
		font-size: 0.96rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.9rem;
	}
</style>
