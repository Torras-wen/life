---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cover from '../../components/Cover.astro';
import FormattedDate from '../../components/FormattedDate.astro';

interface Props {
	entry: CollectionEntry<'journal'>;
}

export async function getStaticPaths() {
	const entries = (await getCollection('journal')).sort(
		(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
	);
	return entries.map((entry, i) => ({
		params: { slug: entry.id },
		props: {
			entry,
			newer: entries[i - 1] ?? null,
			older: entries[i + 1] ?? null,
		},
	}));
}

const { entry } = Astro.props;
const { newer, older } = Astro.props as Props & {
	newer: CollectionEntry<'journal'> | null;
	older: CollectionEntry<'journal'> | null;
};
const { Content } = await render(entry);
const { data } = entry;
---

<BaseLayout title={data.title} description={data.summary}>
	<main>
		<a class="back-link" href="/journal/" data-reveal>
			<span aria-hidden="true">←</span> 旅程
		</a>

		<header class="entry-header">
			<span class="kicker" data-reveal>{data.location}</span>
			<h1 class="hero-title" data-reveal>{data.title}</h1>
			<div class="entry-meta" data-reveal>
				<FormattedDate date={data.date} />
				{data.dateEnd && (
					<>
						<span class="date-sep" aria-hidden="true">–</span>
						<FormattedDate date={data.dateEnd} />
					</>
				)}
				{data.author && (
					<span class="byline">· {data.author === '一起' ? '我们一起写下' : `${data.author} 记录`}</span>
				)}
				{data.mood && <span class="mood">· {data.mood}</span>}
			</div>
			{
				data.tags.length > 0 && (
					<div class="entry-tags" data-reveal>
						{data.tags.map((t) => (
							<span class="tag">{t}</span>
						))}
					</div>
				)
			}
		</header>

		<div class="hero-media" data-reveal>
			<Cover
				seed={data.title}
				image={data.cover}
				imageAlt={data.coverAlt}
				label={data.location}
			/>
		</div>

		<article class="prose">
			<Content />
		</article>

		{
			data.itinerary.length > 0 && (
				<section class="itinerary" data-reveal>
					<div class="sec-head">
						<span class="chapter-no">.行程</span>
						<h2>每天的足迹</h2>
					</div>
					<ol class="trip">
						{data.itinerary.map((d) => (
							<li class="trip-day">
								<span class="trip-daynum">{d.day}</span>
								<div class="trip-body">
									<h3>{d.title}</h3>
									{d.note && <p>{d.note}</p>}
								</div>
							</li>
						))}
					</ol>
				</section>
			)
		}

		{
			data.gallery.length > 0 && (
				<section class="gallery-sec" data-reveal>
					<div class="sec-head">
						<span class="chapter-no">.相册</span>
						<h2>这一路的照片</h2>
					</div>
					<div class="photo-grid">
						{data.gallery.map((src) => (
							<figure class="photo">
								<img src={src} alt="" loading="lazy" decoding="async" />
							</figure>
						))}
					</div>
				</section>
			)
		}

		<nav class="entry-nav" aria-label="相邻旅程">
			{
				older ? (
					<a class="nav-card prev" href={`/journal/${older.id}/`}>
						<span class="nav-dir">← 上一程</span>
						<span class="nav-title">{older.data.title}</span>
						<span class="nav-loc">{older.data.location}</span>
					</a>
				) : (
					<span />
				)
			}
			{
				newer ? (
					<a class="nav-card next" href={`/journal/${newer.id}/`}>
						<span class="nav-dir">下一程 →</span>
						<span class="nav-title">{newer.data.title}</span>
						<span class="nav-loc">{newer.data.location}</span>
					</a>
				) : (
					<span />
				)
			}
		</nav>
	</main>
</BaseLayout>

<style>
	main {
		width: var(--container-wide);
		padding-top: 2.5rem;
	}
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--text-muted);
	}
	.back-link:hover {
		color: var(--accent);
	}

	.entry-header {
		max-width: var(--container);
		margin: 2rem auto 0;
		text-align: center;
	}
	.hero-title {
		margin: 1rem 0 0;
		font-size: clamp(2.2rem, 5.5vw, 3.6rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
	}
	.entry-meta {
		margin-top: 1rem;
		font-size: 0.92rem;
		color: var(--text-faint);
	}
	.mood {
		font-family: var(--font-serif);
		font-style: italic;
	}
	.byline {
		color: var(--love);
		font-weight: 500;
	}
	.entry-tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.45rem;
		margin-top: 1.2rem;
	}

	.hero-media {
		margin: 3rem 0;
		overflow: hidden;
		border-radius: var(--radius-xl);
		aspect-ratio: 16 / 9;
		background: var(--bg-subtle);
		box-shadow: var(--shadow);
	}
	.hero-media :global(.cover) {
		height: 124%;
		will-change: transform;
	}

	.prose {
		max-width: var(--container);
		margin-inline: auto;
		font-size: 1.12rem;
	}
	.prose :global(h2),
	.prose :global(h3) {
		max-width: 100%;
	}
	.prose :global(img) {
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		margin: 2rem 0;
	}

	.date-sep {
		margin: 0 0.5rem;
		color: var(--text-faint);
	}

	/* 按天行程 + 画廊 共用区头 */
	.itinerary,
	.gallery-sec {
		max-width: var(--container);
		margin: 4rem auto 0;
	}
	.sec-head {
		display: flex;
		align-items: baseline;
		gap: 0.85rem;
		padding-top: 1.2rem;
		margin-bottom: 1.8rem;
		border-top: 1px solid var(--border);
	}
	.sec-head h2 {
		margin: 0;
		font-size: clamp(1.4rem, 3vw, 1.9rem);
	}
	.chapter-no {
		font-family: var(--font-mono);
		font-size: 0.76rem;
		letter-spacing: 0.1em;
		color: var(--accent);
	}

	/* 行程时间线 */
	.trip {
		list-style: none;
		margin: 0;
		padding: 0;
		border-left: 2px solid var(--border);
	}
	.trip-day {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.4rem;
		padding: 0 0 2.2rem 1.8rem;
	}
	.trip-day:last-child {
		padding-bottom: 0;
	}
	.trip-day::before {
		content: '';
		position: absolute;
		left: -7px;
		top: 6px;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 4px var(--bg);
	}
	.trip-daynum {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--accent);
		white-space: nowrap;
		padding-top: 0.2rem;
	}
	.trip-body h3 {
		margin: 0 0 0.35rem;
		font-size: 1.25rem;
	}
	.trip-body p {
		margin: 0;
		color: var(--text-muted);
	}

	/* 多图画廊 —— 瀑布流 */
	.photo-grid {
		columns: 2;
		column-gap: 1rem;
	}
	@media (min-width: 720px) {
		.photo-grid {
			columns: 3;
		}
	}
	.photo {
		margin: 0 0 1rem;
		break-inside: avoid;
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--bg-subtle);
		box-shadow: var(--shadow-sm);
	}
	.photo img {
		display: block;
		width: 100%;
		height: auto;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.photo:hover img {
		transform: scale(1.05);
	}
	.photo figcaption {
		padding: 0.5rem 0.85rem;
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	/* 邻程导航 */
	.entry-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		max-width: var(--container);
		margin: 5rem auto 0;
		padding-top: 2.5rem;
		border-top: 1px solid var(--border);
	}
	.nav-card {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		color: inherit;
		transition:
			border-color 0.25s ease,
			background-color 0.25s ease,
			transform 0.25s ease;
	}
	.nav-card:hover {
		border-color: var(--accent);
		background: var(--surface-hover);
		transform: translateY(-2px);
	}
	.nav-card.next {
		text-align: right;
	}
	.nav-dir {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent);
	}
	.nav-title {
		margin-top: 0.3rem;
		font-family: var(--font-serif);
		font-size: 1.15rem;
		font-weight: 560;
		color: var(--text);
	}
	.nav-loc {
		font-size: 0.8rem;
		color: var(--text-faint);
	}

	@media (max-width: 600px) {
		.entry-nav {
			grid-template-columns: 1fr;
		}
		.nav-card.next {
			text-align: left;
		}
	}
</style>
