---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('journal');
const places = [...new Set(entries.map((e) => e.data.location))];

const records = [
	{ t: '远途', d: '山川湖海，异国街巷，那些要坐很久车才能抵达的地方。' },
	{ t: '附近', d: '城市的角落、周末的短途，原来熟悉的地方也有没见过的光。' },
	{ t: '日常', d: '一顿饭、一场雨、一段下班的路 —— 生活本身也值得收藏。' },
];

const ways = [
	{ n: '01', t: '慢一点', d: '宁可少看一个景点，也要在巷口多坐一会儿。' },
	{ n: '02', t: '写下来', d: '当天的天气、味道和心情，趁还热乎时记下。' },
	{ n: '03', t: '不赶路', d: '把通勤也当成风景，地铁与渡轮都算数。' },
	{ n: '04', t: '带回家', d: '一张车票、一颗石子，都是这趟旅程的证据。' },
];

// 两位主人。名字、角色和介绍都可以随意改。
const people = [
	{
		initial: 'WJ',
		name: 'WJ',
		role: '出发的人',
		d: '负责规划路线，也负责把车开到没有信号的地方。地图上每一个想去的点，多半是他先标下的。',
	},
	{
		initial: 'GB',
		name: 'GB',
		role: '记得的人',
		d: '总能找到巷子里最好吃的那家，也总在当天把心情写下来。这本册子里温柔的句子，多半出自她手。',
	},
];
---

<BaseLayout title="关于" description="关于这本记录生活与旅行的册子。">
	<main class="about">
		<section class="page-hero">
			<span class="kicker" data-reveal>ABOUT</span>
			<h1 class="hero-title">
				<span class="line">关于我们俩</span>
			</h1>
			<p class="lede" data-reveal>
				这里不写攻略，也不赶热点。只是 WJ 和 GB 两个人，把一起走过的路、见过的光，和那些舍不得忘记的瞬间，慢慢存下来。
			</p>
		</section>

		<section class="intro" data-reveal>
			<p>
				我们一个叫 WJ，一个叫 GB。喜欢一起出发，也喜欢一起回来；喜欢在陌生的城市迷一次路，也喜欢在熟悉的街角分享同一杯咖啡。比起「去过」，我们更在意「一起记得」——
				记得那天的风，记得那碗汤的温度，记得当时彼此在想什么。
			</p>
			<p>
				于是有了这个地方。它像一本两个人一起翻阅的相册，又像写给未来的我们的信。如果你也路过这里，欢迎一起慢慢看。
			</p>
		</section>

		<section class="records">
			<div class="rule" data-reveal><span class="kicker">记录什么</span></div>
			<div class="record-grid">
				{
					records.map((r) => (
						<div class="record-card" data-reveal>
							<h3>{r.t}</h3>
							<p>{r.d}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="ways">
			<div class="rule" data-reveal><span class="kicker">我们的方式</span></div>
			<ul class="way-list">
				{
					ways.map((w) => (
						<li data-reveal>
							<span class="way-num">{w.n}</span>
							<span class="way-body">
								<span class="way-title">{w.t}</span>
								<span class="way-desc">{w.d}</span>
							</span>
						</li>
					))
				}
			</ul>
		</section>

		<section class="duo">
			<div class="rule" data-reveal><span class="kicker">我们是谁</span></div>
			<div class="duo-grid">
				{
					people.map((p) => (
						<div class="person-card" data-reveal>
							<span class="person-badge">{p.initial}</span>
							<div class="person-info">
								<h3>{p.name}</h3>
								<span class="person-role">{p.role}</span>
								<p>{p.d}</p>
							</div>
						</div>
					))
				}
			</div>
			<p class="duo-note" data-reveal>WJ &amp; GB —— 一个负责出发，一个负责记得。</p>
		</section>

		{
			places.length > 0 && (
				<section class="places">
					<div class="rule" data-reveal>
						<span class="kicker">去过的地方</span>
					</div>
					<div class="place-cloud" data-reveal>
						{places.map((p) => (
							<span class="place">{p}</span>
						))}
					</div>
				</section>
			)
		}

		<section class="contact" data-reveal>
			<div class="contact-inner">
				<h2>想一起走走，或随便聊聊？</h2>
				<p>路上见，或者写封信给我们。</p>
				<div class="contact-actions">
					<a class="button button-primary" href="mailto:hello@example.com">写封信</a>
					<a class="button button-ghost" href="/journal/">翻翻旅程</a>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	main {
		width: var(--container-wide);
	}
	.page-hero {
		padding: 3rem 0 2rem;
	}
	.hero-title {
		margin: 1rem 0 0;
		font-size: clamp(2.6rem, 7vw, 4.2rem);
		letter-spacing: -0.025em;
	}
	.hero-title .line {
		display: block;
	}
	.lede {
		margin: 1.4rem 0 0;
		max-width: 42rem;
		font-size: clamp(1.15rem, 2.5vw, 1.4rem);
		font-family: var(--font-serif);
		color: var(--text-muted);
		line-height: 1.5;
	}

	.intro {
		max-width: var(--container);
		margin: 2.5rem 0 0;
		font-size: 1.1rem;
		color: var(--text-muted);
	}
	.intro p {
		margin-bottom: 1.2em;
	}

	.rule {
		padding-top: 1.2rem;
		border-top: 1px solid var(--border);
		margin-bottom: 2rem;
	}

	.records {
		margin-top: 5rem;
	}
	.record-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.record-card {
		padding: 1.8rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		transition:
			border-color 0.25s ease,
			transform 0.25s ease;
	}
	.record-card:hover {
		border-color: var(--accent);
		transform: translateY(-3px);
	}
	.record-card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.4rem;
		color: var(--accent);
	}
	.record-card p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.98rem;
	}

	.ways {
		margin-top: 5rem;
	}
	.way-list {
		list-style: none;
		margin: 0;
		padding: 0;
		max-width: var(--container);
	}
	.way-list li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.5rem;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--border);
	}
	.way-num {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		color: var(--text-faint);
		padding-top: 0.3rem;
	}
	.way-body {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.way-title {
		font-family: var(--font-serif);
		font-size: 1.5rem;
		font-weight: 560;
		color: var(--text);
	}
	.way-desc {
		color: var(--text-muted);
	}

	/* 我们是谁 */
	.duo {
		margin-top: 5rem;
	}
	.duo-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}
	.person-card {
		display: flex;
		gap: 1.2rem;
		align-items: flex-start;
		padding: 1.8rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		transition:
			border-color 0.25s ease,
			transform 0.25s ease;
	}
	.person-card:hover {
		border-color: var(--accent);
		transform: translateY(-3px);
	}
	.person-badge {
		flex: none;
		display: grid;
		place-items: center;
		width: 3.2rem;
		height: 3.2rem;
		border-radius: 50%;
		background: var(--accent-soft);
		color: var(--accent);
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: 1.05rem;
		letter-spacing: 0.03em;
	}
	.person-info h3 {
		margin: 0;
		font-size: 1.3rem;
	}
	.person-role {
		display: block;
		margin: 0.2rem 0 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-faint);
	}
	.person-info p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.96rem;
	}
	.duo-note {
		margin: 1.8rem 0 0;
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1.05rem;
		color: var(--text-muted);
	}

	.places {
		margin-top: 5rem;
	}
	.place-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}
	.place {
		padding: 0.55rem 1.1rem;
		border-radius: var(--radius-pill);
		background: var(--bg-subtle);
		border: 1px solid var(--border);
		font-family: var(--font-serif);
		font-size: 1.05rem;
		color: var(--text);
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease;
	}
	.place:hover {
		color: var(--accent);
		border-color: var(--accent);
		background: var(--accent-soft);
	}

	.contact {
		margin: 6rem 0 2rem;
	}
	.contact-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding: clamp(3rem, 8vw, 5rem) 2rem;
		text-align: center;
		background: var(--bg-subtle);
		border: 1px solid var(--border);
		border-radius: var(--radius-xl);
	}
	.contact-inner h2 {
		margin: 0;
		font-size: clamp(1.6rem, 4vw, 2.4rem);
	}
	.contact-inner p {
		margin: 0;
		color: var(--text-muted);
	}
	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		justify-content: center;
		margin-top: 1rem;
	}

	@media (max-width: 760px) {
		.record-grid {
			grid-template-columns: 1fr;
		}
		.duo-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
